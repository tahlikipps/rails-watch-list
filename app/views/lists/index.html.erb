<div class="navbar-lewagon">
  <h3> <i class="fa-solid fa-popcorn"></i>Movies 'R' Us</h3>
</div>

<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(https://cdn.pixabay.com/photo/2018/04/01/17/54/people-3281583_1280.jpg);">
  <div class="container">
    <h1>Movie Lists</h1>
    <p>
    <span data-controller="typed-js"></span>
    </p>
  </div>
</div>
<div class="container">
  <div class="cards">
    <% @lists.each do |list| %>
      <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= cl_image_path list.photo.key, height: 300, crop: :fill %>')">
      <%= link_to list.name, list_path(list) %>
      </div>
    <% end %>
      <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url(https://images.unsplash.com/photo-1633613286848-e6f43bbafb8d?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1470&q=80);">
      <i class="fa-solid fa-circle-plus fa-beat"></i> <%= link_to " Add a new list", new_list_path %>
  </div>

</div>
</div>
